<Project Sdk="Godot.NET.Sdk/4.5.1">
    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
        <EnableDefaultNoneItems>false</EnableDefaultNoneItems>
        <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    </PropertyGroup>

    <ItemGroup>
        <AdditionalFiles Include="Collector/localization/**/*.json"/>
        <Compile Remove="Collector/**"/>
        <EmbeddedResource Remove="Collector/**"/>
        <None Include="Collector.json"/>
        <None Include="Collector/**"/>
        <None Include="CollectorCode/**"/>
        <Content Include="cardloc-presets.json"/>
        <Compile Include="CollectorCode/**/*.cs"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="Downfall.csproj"/>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Update="Alchyr.Sts2.ModAnalyzers" Version="0.1.9" />
    </ItemGroup>
</Project>